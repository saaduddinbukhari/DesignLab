{%- comment -%} Pull in our custom scoped app-extension stylesheet instead of CDN Tailwind {%- endcomment -%}
{{ 'design-lab-extension.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  We read Prestige's raw RGB tokens directly inside a scoped block style tag 
  so we can map them gracefully to variables without leaking styles.
{%- endcomment -%}
<style>
  .client-3d-designer-extension {
    --app-bg: var(--background-gradient, rgb(var(--background-without-opacity, 253 249 243)));
    --app-text: rgb(var(--text-color, 23 25 27));
    --app-border: rgb(var(--border-color, 223 227 231));
    --app-btn-bg: rgb(var(--button-background, 23 25 27));
    --app-btn-text: rgb(var(--button-text-color, 255 255 255));
  }
</style>

<div 
  id="design-lab-root" 
  data-shop-domain="{{ shop.domain }}"
  data-loading-animation-url="{{ 'loading-animation.json' | asset_url }}"
  class="client-3d-designer-extension"
>
  <p style="text-align: center; padding: 40px; font-family: var(--text-font-family), sans-serif;">
    Loading Design Lab Interface...
  </p>
</div>

<script src="{{ 'design-lab-frontend.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Design Lab Interface",
  "target": "section",
  "templates": ["collection", "page"],
  "settings": []
}
{% endschema %}